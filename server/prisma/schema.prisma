// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum CategoriaLivro {
  ROMANCE
  INFANTIL
  TECNOLOGIA
  HISTORIA
  CIENCIAS
}

enum StatusEmprestimo {
  EM_ANDAMENTO
  DEVOLVIDO
  ATRASADO
}

model Livro {
  id                    String        @id @default(uuid())
  titulo                String
  autor                 String
  isbn                  String        @unique
  editora               String
  ano                   Int
  quantidadeTotal       Int
  quantidadeDisponivel  Int
  categoria             CategoriaLivro
  emprestimos           Emprestimo[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model Emprestimo {
  id                    String             @id @default(uuid())
  livroId               String
  livro                 Livro              @relation(fields: [livroId], references: [id])
  nomeCliente           String
  emailCliente          String
  dataLocacao           DateTime           @default(now())
  dataPrevistaDevolucao DateTime
  status                StatusEmprestimo   @default(EM_ANDAMENTO)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  sentMail              SentMail?
}

model SentMail {
  id      String     @id @default(uuid())
  loanId  String     @unique
  loan    Emprestimo @relation(fields: [loanId], references: [id])
}